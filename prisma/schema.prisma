generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  VIEWER
}

enum UserApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  CLOSED
}

enum ChangeType {
  QUANTITY
  AMOUNT
  MIXED
}

enum ChangeStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

enum DiscountMode {
  NONE
  PERCENTAGE
  AMOUNT
  QUANTITY
}

enum MonthlyClosureStatus {
  CLOSED
  REPLACED
}

model User {
  id           String    @id @default(cuid())
  authUserId   String?   @unique
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole
  approvalStatus UserApprovalStatus @default(APPROVED)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Contract {
  id             String               @id @default(cuid())
  code           String               @unique
  name           String
  clientName     String
  description    String?
  startDate      DateTime?
  endDate        DateTime?
  currency       String               @default("CLP")
  originalAmount Decimal              @db.Decimal(18, 2)
  status         ContractStatus       @default(DRAFT)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  itemFamilies   ItemFamily[]
  items          ContractItem[]
  changes        ContractChange[]
  monthlyClosures MonthlyClosure[]
}

model MeasurementUnit {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ItemFamily {
  id          String          @id @default(cuid())
  contractId  String?
  code        String
  name        String
  wbs         String?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  contract    Contract?       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  subfamilies ItemSubfamily[]

  @@unique([contractId, code])
  @@index([contractId])
}

model ItemSubfamily {
  id        String            @id @default(cuid())
  familyId  String
  code      String
  name      String
  wbs       String?
  active    Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  family    ItemFamily        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  groups    ItemGroupCatalog[]

  @@unique([familyId, code])
  @@index([familyId])
}

model ItemGroupCatalog {
  id          String         @id @default(cuid())
  subfamilyId String
  code        String
  name        String
  wbs         String?
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  subfamily   ItemSubfamily  @relation(fields: [subfamilyId], references: [id], onDelete: Cascade)

  @@unique([subfamilyId, code])
  @@index([subfamilyId])
}

model ContractItem {
  id                String               @id @default(cuid())
  contractId        String
  family            String?
  subfamily         String?
  itemGroup         String?
  itemNumber        String
  itemCode          String
  description       String
  unit              String?
  originalQuantity  Decimal              @db.Decimal(18, 3)
  unitPrice         Decimal              @db.Decimal(18, 2)
  originalAmount    Decimal              @db.Decimal(18, 2)
  currentQuantity   Decimal?             @db.Decimal(18, 3)
  currentAmount     Decimal?             @db.Decimal(18, 2)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  contract          Contract             @relation(fields: [contractId], references: [id], onDelete: Cascade)
  consumptions      MonthlyConsumption[]
  changes           ContractChange[]
  changeLines       ContractChangeLine[]
  closureSnapshots  MonthlyClosureItemSnapshot[]

  @@unique([contractId, itemNumber])
  @@unique([contractId, itemCode])
  @@index([contractId])
}

model MonthlyConsumption {
  id                    String         @id @default(cuid())
  contractItemId        String
  year                  Int
  month                 Int
  quantityConsumed      Decimal        @db.Decimal(18, 3)
  amountConsumed        Decimal        @db.Decimal(18, 2)
  discountMode          DiscountMode   @default(NONE)
  discountPercent       Decimal?       @db.Decimal(7, 4)
  discountQuantity      Decimal?       @db.Decimal(18, 3)
  discountAmount        Decimal?       @db.Decimal(18, 2)
  payableQuantity       Decimal?       @db.Decimal(18, 3)
  payableAmount         Decimal?       @db.Decimal(18, 2)
  note                  String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  contractItem          ContractItem   @relation(fields: [contractItemId], references: [id], onDelete: Cascade)

  @@unique([contractItemId, year, month])
  @@index([year, month])
}

model MonthlyClosure {
  id                String                     @id @default(cuid())
  contractId        String
  year              Int
  month             Int
  statementNumber   String?
  status            MonthlyClosureStatus       @default(CLOSED)
  version           Int                        @default(1)
  replacedById      String?
  replacedAt        DateTime?
  approvedAt        DateTime?
  sourceClosureId   String?
  closedAt          DateTime                   @default(now())
  summaryNote       String?
  grossAmount       Decimal?                   @db.Decimal(18, 2)
  totalDiscounts    Decimal?                   @db.Decimal(18, 2)
  netAmount         Decimal?                   @db.Decimal(18, 2)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  contract          Contract                   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  replacedBy        MonthlyClosure?            @relation("ClosureReplacement", fields: [replacedById], references: [id], onDelete: SetNull)
  replacementFor    MonthlyClosure[]           @relation("ClosureReplacement")
  sourceClosure     MonthlyClosure?            @relation("ClosureSource", fields: [sourceClosureId], references: [id], onDelete: SetNull)
  derivedClosures   MonthlyClosure[]           @relation("ClosureSource")
  itemSnapshots     MonthlyClosureItemSnapshot[]

  @@unique([contractId, year, month, version])
  @@index([year, month])
  @@index([status])
  @@index([replacedById])
  @@index([sourceClosureId])
}

model MonthlyClosureItemSnapshot {
  id                      String          @id @default(cuid())
  monthlyClosureId        String
  contractItemId          String
  itemNumber              String
  itemCode                String
  description             String
  unit                    String?
  contractQuantity        Decimal         @db.Decimal(18, 3)
  contractAmount          Decimal         @db.Decimal(18, 2)
  consumedToDateQuantity  Decimal         @db.Decimal(18, 3)
  consumedToDateAmount    Decimal         @db.Decimal(18, 2)
  monthQuantity           Decimal         @db.Decimal(18, 3)
  monthGrossAmount        Decimal         @db.Decimal(18, 2)
  discountMode            DiscountMode    @default(NONE)
  discountPercent         Decimal?        @db.Decimal(7, 4)
  discountQuantity        Decimal?        @db.Decimal(18, 3)
  discountAmount          Decimal?        @db.Decimal(18, 2)
  netPayableQuantity      Decimal?        @db.Decimal(18, 3)
  netPayableAmount        Decimal?        @db.Decimal(18, 2)
  note                    String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  monthlyClosure          MonthlyClosure  @relation(fields: [monthlyClosureId], references: [id], onDelete: Cascade)
  contractItem            ContractItem    @relation(fields: [contractItemId], references: [id], onDelete: Restrict)

  @@unique([monthlyClosureId, contractItemId])
  @@index([contractItemId])
}

model ContractChange {
  id            String        @id @default(cuid())
  contractId    String
  contractItemId String?
  title         String
  description   String?
  type          ChangeType
  status        ChangeStatus  @default(PENDING)
  quantityDelta Decimal?      @db.Decimal(18, 3)
  amountDelta   Decimal?      @db.Decimal(18, 2)
  effectiveDate DateTime
  approvedAt    DateTime?
  rejectedAt    DateTime?
  appliedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  contract      Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractItem   ContractItem? @relation(fields: [contractItemId], references: [id], onDelete: SetNull)
  lines         ContractChangeLine[]

  @@index([contractId])
  @@index([contractItemId])
  @@index([status])
}

model ContractChangeLine {
  id                    String          @id @default(cuid())
  contractChangeId      String
  contractItemId        String?
  createsNewItem        Boolean         @default(false)
  family                String?
  subfamily             String?
  itemGroup             String?
  itemNumber            String
  itemCode              String
  description           String
  unit                  String?
  quantityDelta         Decimal?        @db.Decimal(18, 3)
  amountDelta           Decimal         @db.Decimal(18, 2)
  unitPrice             Decimal?        @db.Decimal(18, 2)
  beforeQuantity        Decimal?        @db.Decimal(18, 3)
  beforeAmount          Decimal?        @db.Decimal(18, 2)
  afterQuantity         Decimal?        @db.Decimal(18, 3)
  afterAmount           Decimal?        @db.Decimal(18, 2)
  appliedAt             DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  contractChange        ContractChange  @relation(fields: [contractChangeId], references: [id], onDelete: Cascade)
  contractItem          ContractItem?   @relation(fields: [contractItemId], references: [id], onDelete: SetNull)

  @@index([contractChangeId])
  @@index([contractItemId])
}
