{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "buildAptPackages": [],
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        {
          "cmd": "npm ci --include=dev --no-audit --no-fund --prefer-offline",
          "customName": "Install Node dependencies"
        }
      ]
    },
    "build": {
      "inputs": [
        {
          "step": "install"
        }
      ],
      "commands": [
        "npm run build",
        "mkdir -p .next/standalone/.next",
        "cp -r public .next/standalone/",
        "cp -r .next/static .next/standalone/.next/"
      ]
    }
  },
  "deploy": {
    "startCommand": "node .next/standalone/server.js"
  }
}
